{
  "name": "webgl-prototypes",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "compress:models": "gltf-transform optimize public/cottage.glb public/cottage.glb --compress draco --texture-compress webp --texture-size 2048 && gltf-transform optimize public/wizard.glb public/wizard.glb --compress draco --texture-compress webp --texture-size 1024",
    "copy:draco": "mkdir -p public/draco && cp node_modules/three/examples/jsm/libs/draco/gltf/* public/draco/",
    "postinstall": "npm run copy:draco"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "lil-gui": "^0.21.0",
    "three": "^0.183.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "vite": "^8.0.3",
    "vite-plugin-glsl": "^1.5.6",
    "vitest": "^3.1.1"
  }
}
